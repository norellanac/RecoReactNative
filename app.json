{
  "expo": {
    "name": "Reco",
    "slug": "Reco",
    "version": "0.2.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tu galería para seleccionar una imagen.",
        "NSCameraUsageDescription": "Necesitamos acceso a tu cámara para tomar una foto."
      }
    },
    "android": {
        "permissions": [
          "READ_MEDIA_IMAGES",
          "READ_EXTERNAL_STORAGE",
          "WRITE_EXTERNAL_STORAGE",
          "CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "gt.com.reco.app"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "ios": {
            "backgroundColor": "#ffffff",
            "image": "./assets/images/icon.png",
            "resizeMode": "cover"
          },
          "android": {
            "backgroundColor": "#ffffff",
            "image": "./assets/images/icon.png",
            "imageWidth": 240
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "98712f33-47b0-4bf5-b2cc-d91b0524ad16"
      }
    }
  }
}
