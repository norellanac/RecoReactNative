{
  "expo": {
    "name": "Reco",
    "slug": "Reco",
    "version": "0.7.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tu galería para seleccionar una imagen.",
        "NSCameraUsageDescription": "Necesitamos acceso a tu cámara para tomar una foto."
      }
    },
    "android": {
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "gt.com.reco.app"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/98712f33-47b0-4bf5-b2cc-d91b0524ad16"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/icon.png",
          "resizeMode": "contain",
          "imageWidth": 200
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-sqlite",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "98712f33-47b0-4bf5-b2cc-d91b0524ad16"
      },
      "EXPO_PUBLIC_API_URL": "https://dev.recolatam.com/api/v1"
    }
  }
}
