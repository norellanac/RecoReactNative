{
  "cli": {
    "version": ">= 16.6.2",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "ENVIRONMENT": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "ENVIRONMENT": "development",
        "EXPO_PUBLIC_API_URL": "https://dev.recolatam.com/api/v1"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "ENVIRONMENT": "production",
        "EXPO_PUBLIC_API_URL": "https://api.recolatam.com/api/v1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
