{
  "expo": {
    "name": "Reco",
    "slug": "Reco",
    "version": "0.0.1",
    "orientation": "portrait",
    "newArchEnabled": true,
    "icon": "app/assets/img/Reco_logo.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tu galería para seleccionar una imagen.",
        "NSCameraUsageDescription": "Necesitamos acceso a tu cámara para tomar una foto."
      }
    },
    "android": {
        "permissions": [
          "READ_MEDIA_IMAGES",
          "READ_EXTERNAL_STORAGE",
          "WRITE_EXTERNAL_STORAGE",
          "CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ]
  }
}
